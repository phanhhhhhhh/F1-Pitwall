# F1 Pitwall Backend — Environment Variables
# Copy this file to .env and fill in your values.
# For local development, the defaults in application.properties are sufficient.

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/f1_pitwall_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters for HS256 signing
JWT_SECRET=your-super-secret-key-minimum-32-chars-here

# ── Seeded user passwords ─────────────────────────────────────────────────────
# Used by DataSeeder on first startup. Override for production.
ADMIN_PASSWORD=pitwall2024
ENGINEER_PASSWORD=telemetry2024

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Google OAuth2 ────────────────────────────────────────────────────────────
# Leave as dummy-local for local dev (OAuth login will be disabled)
GOOGLE_CLIENT_ID=dummy-local
GOOGLE_CLIENT_SECRET=dummy-local

# ── Gmail SMTP (required for OTP email) ──────────────────────────────────────
# Use a Gmail App Password: myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ── Production only ───────────────────────────────────────────────────────────
# Full backend URL (used for OAuth2 redirect URI)
BACKEND_URL=https://your-backend.onrender.com

# ── Deployment ────────────────────────────────────────────────────────────────
# Set SPRING_PROFILES_ACTIVE=prod in production to use application-prod.properties
SPRING_PROFILES_ACTIVE=dev
