# F1 Pitwall Backend — Environment Variables
# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL DEV: application.properties hardcodes postgres:postgres@localhost:5432/f1_pitwall_db.
#   No env vars needed — just make sure PostgreSQL is running on port 5432.
# PRODUCTION: application-prod.properties reads these env vars:
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=f1_pitwall_db
# PGUSER=postgres
# PGPASSWORD=your-prod-password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters for HS256 signing
JWT_SECRET=your-super-secret-key-minimum-32-chars-here

# ── Seeded user passwords ─────────────────────────────────────────────────────
# Used by UserSeeder on first startup. Defaults shown below.
ADMIN_PASSWORD=pitwall2024
ENGINEER_PASSWORD=telemetry2024

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Google OAuth2 ────────────────────────────────────────────────────────────
# Leave as dummy-local for local dev (OAuth login button still appears but uses no-op credentials)
GOOGLE_CLIENT_ID=dummy-local
GOOGLE_CLIENT_SECRET=dummy-local

# ── Resend Email API (for OTP codes) ─────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=onboarding@resend.dev

# ── Production only ───────────────────────────────────────────────────────────
# Full backend URL (used for OAuth2 redirect URI)
BACKEND_URL=https://your-backend.onrender.com

# ── Deployment ────────────────────────────────────────────────────────────────
# Set to "prod" in production to load application-prod.properties
# (there is no application-dev.properties — leaving this empty or "dev" uses defaults)
SPRING_PROFILES_ACTIVE=dev
